---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<style>
			main {
				max-width: 720px;
				margin: 0 auto;
				padding: 2em 1em;
			}
			.hero {
				margin-bottom: 3em;
			}
			.hero h1 {
				font-size: 2.5em;
				margin-bottom: 0.2em;
			}
			.hero p {
				font-size: 1.1em;
				color: rgb(var(--gray));
			}
			.sections {
				display: grid;
				grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
				gap: 1.5em;
			}
			.card {
				border: 1px solid rgb(var(--gray-light));
				border-radius: 8px;
				padding: 1.5em;
				transition: box-shadow 0.2s;
			}
			.card:hover {
				box-shadow: var(--box-shadow);
			}
			.card h3 {
				margin: 0 0 0.5em 0;
				font-size: 0.95em;
			}
			.card p {
				margin: 0;
				color: rgb(var(--gray));
				font-size: 0.95em;
			}
			.card a {
				text-decoration: none;
				color: inherit;
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<div class="hero">
				<p>Welcome to my space, where I log my study notes, projects, and thoughts. I'm a full stack data scientist with an applied math background.
				</p>
			</div>
			<div class="sections">
				<div class="card">
					<a href="/blog">
						<h3>📝 Blog</h3>
						<p>Thoughts on data science, machine learning, and beyond.</p>
					</a>
				</div>
				<div class="card">
					<a href="/notes">
						<h3>📚 Self Study Notes</h3>
						<p>Notes on math, statistics, and topics I'm exploring.</p>
					</a>
				</div>
				<div class="card">
					<a href="/projects">
						<h3>🛠️ Projects</h3>
						<p>Things I've built and experiments I've run.</p>
					</a>
				</div>
			</div>
		</main>
		<Footer />
	</body>
</html>